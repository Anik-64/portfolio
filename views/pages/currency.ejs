<div class="container mx-auto">
    <!-- Floating message container -->
    <div id="floatingMessage" class="floating-message"></div>

    <div class="flex justify-between items-center mt-4 mb-6 flex-col sm:flex-row gap-4 sm:gap-0 page-header">
        <h1 class="text-xl font-bold"><%= title %></h1>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-2 w-full sm:w-auto">
            <button id="addCurrencyBtn" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded w-full sm:w-auto">
                <i class="fas fa-plus text-xs"></i>
            </button>
            <input id="searchInput" type="text" placeholder="Search currencies..." 
                class="border rounded px-3 py-2 w-full sm:w-64 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
    </div>

    <!-- Currency Table -->
    <div class="bg-white shadow-md rounded-lg p-4 md:p-6">
        <div class="table-container">
            <div class="table-responsive">
                <table id="currencyTable" class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium  uppercase tracking-wider cid-column">ID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium  uppercase tracking-wider cid-column">Currency ID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium  uppercase tracking-wider ctext-column">Currency Text</th>
                            <th class="px-4 py-3 text-right text-xs font-medium  uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <!-- Data will be loaded via JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Currency Modal -->
<div id="currencyModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50">
    <div class="bg-white rounded-lg w-full max-w-lg modal-content">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold" id="modalTitle">Add Currency</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeModal">
                <span>×</span>
            </button>
        </div>
        <div class="modal-form-container p-4">
            <span class="text-xs text-gray-500 italic block mb-2"><span class="text-red-500">*</span> = Required</span>
            <form id="currencyForm">
                <!-- <div class="modal-form-grid"> -->
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            Currency ID <span class="text-red-500">*</span>
                            <input id="cid" name="cid" required
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="Enter currency ID (e.g., USD)" maxlength="10">
                        </label>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            Currency Text <span class="text-red-500">*</span>
                            <input id="ctext" name="ctext" required
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="Enter currency name (e.g., US Dollar)" maxlength="50">
                        </label>
                    </div>
                <!-- </div> -->
                <div class="text-center mt-4">
                    <button type="submit" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 w-full sm:w-auto">
                        Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50">
    <div class="bg-white rounded-lg w-full max-w-md modal-content">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold">Confirm Delete</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeDeleteModal">
                <span>×</span>
            </button>
        </div>
        <div class="p-4">
            <p class="mb-4">Are you sure you want to delete this currency?</p>
            <div class="flex justify-end space-x-2">
                <button id="cancelDelete" class="bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 w-full sm:w-auto">
                    Cancel
                </button>
                <button id="confirmDelete" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 w-full sm:w-auto">
                    Delete
                </button>
            </div>
        </div>
    </div>
</div>