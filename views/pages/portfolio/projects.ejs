<!-- Project Detail Modal -->
<div id="projectDetailModal" class="fixed inset-0 z-[200] hidden items-center justify-center p-4">
    
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="closeProjectDetailModal"></div>

    <!-- Modal — landscape: image left, content right -->
    <div class="relative w-full max-w-4xl max-h-[85vh] bg-white dark:bg-dark-card rounded-2xl shadow-2xl flex flex-row overflow-hidden">

        <!-- LEFT: Image Panel -->
        <div class="w-2/5 flex-shrink-0 bg-gray-100 dark:bg-gray-900 relative">
            <img id="projectModalImage" src="" alt=""
                 class="w-full h-full object-cover absolute inset-0">
        </div>

        <!-- RIGHT: Content Panel -->
        <div class="flex-1 flex flex-col min-w-0 max-h-[85vh]">

            <!-- Header -->
            <div class="flex items-start justify-between px-6 py-4 border-b border-gray-100 dark:border-dark-border flex-shrink-0">
                <h3 id="projectModalTitle" class="text-lg font-bold dark:text-white leading-snug pr-4">
                    Project Title
                </h3>
                <button id="closeProjectDetailBtn"
                        class="p-1.5 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg text-gray-400 flex-shrink-0 mt-0.5">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Tags -->
            <div class="px-6 pt-4 flex-shrink-0">
                <div id="projectModalTags" class="flex flex-wrap gap-2"></div>
            </div>

            <!-- Scrollable Description -->
            <div class="flex-1 overflow-y-auto custom-scrollbar px-6 py-4">
                <p id="projectModalDescription"
                   class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed whitespace-pre-line">
                </p>
            </div>

            <!-- Footer: Links -->
            <div class="px-6 py-4 border-t border-gray-100 dark:border-dark-border flex-shrink-0">
                <div id="projectModalLinks" class="flex flex-wrap gap-3"></div>
            </div>

        </div>
    </div>
</div>

<style type="text/tailwindcss">
    .filter-btn {
        @apply px-5 py-2 text-sm font-medium rounded-lg text-gray-500 transition-all;
    }
    .filter-btn.active {
        @apply bg-white dark:bg-dark-bg text-primary shadow-sm;
    }
    .filter-btn:not(.active):hover {
        @apply text-gray-900 dark:text-white;
    }
</style>
