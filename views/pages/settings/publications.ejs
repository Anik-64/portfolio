<div class="container mx-auto">
    <!-- Floating message container -->
    <div id="floatingMessage" class="floating-message"></div>

    <div class="flex justify-between items-center mt-4 mb-6 flex-col sm:flex-row gap-4 sm:gap-0 page-header">
        <h1 class="text-xl font-bold"><%= title %></h1>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-2 w-full sm:w-auto">
            <button id="addBtn" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded w-full sm:w-auto">
                <i class="fas fa-plus text-xs"></i> Add Publication
            </button>
            <input id="searchInput" type="text" placeholder="Search publications..." 
                class="border rounded px-3 py-2 w-full sm:w-64 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white shadow-md rounded-lg p-4 md:p-6">
        <div class="table-container">
            <div class="table-responsive">
                <table id="dataTable" class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">ID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Thumbnail</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Title</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Journal/Publisher</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Date</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Visible</th>
                            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <!-- Data will be loaded via JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div id="dataModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50 overflow-y-auto">
    <div class="bg-white rounded-lg w-full max-w-2xl modal-content relative my-auto">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold" id="modalTitle">Add Publication</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeModal">
                <span>×</span>
            </button>
        </div>
        <div class="modal-form-container p-4 max-h-[80vh] overflow-y-auto">
            <span class="text-xs text-gray-500 italic block mb-2"><span class="text-red-500">*</span> = Required</span>
            <form id="dataForm">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="mb-4 col-span-1 md:col-span-2">
                        <label class="block mb-1 text-gray-700">
                            Title <span class="text-red-500">*</span>
                            <input id="titleStr" name="title" required
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="e.g., Deep Learning Advances">
                        </label>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            Journal Name
                            <input id="journal_name" name="journal_name"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="e.g., Nature Communications">
                        </label>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            Publisher
                            <input id="publisher" name="publisher"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="e.g., IEEE">
                        </label>
                    </div>
                    <div class="mb-4 col-span-1 md:col-span-2">
                        <label class="block mb-1 text-gray-700">
                            Authors (Comma separated)
                            <input id="authors" name="authors"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="e.g., John Doe, Jane Smith">
                        </label>
                    </div>
                    <div class="mb-4 col-span-1 md:col-span-2">
                        <label class="block mb-1 text-gray-700">
                            Author LinkedIn URLs (Comma separated, matching authors order)
                            <input id="author_linkedin_urls" name="author_linkedin_urls"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="e.g., https://linkedin.com/in/johndoe, https://linkedin.com/in/janesmith">
                        </label>
                    </div>
                    <div class="mb-4 col-span-1 md:col-span-2">
                        <label class="block mb-1 text-gray-700">
                            Author Image URLs (Comma separated, matching authors order)
                            <input id="author_image_urls" name="author_image_urls"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="e.g., https://example.com/p1.jpg, https://example.com/p2.jpg">
                        </label>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            Publication Date
                            <input id="publication_date" name="publication_date"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="date">
                        </label>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            DOI
                            <input id="doi" name="doi"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="text" placeholder="e.g., 10.1038/s41467-020-18151-2">
                        </label>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            Publication URL
                            <input id="publication_url" name="publication_url"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="url" placeholder="https://example.com/publication">
                        </label>
                    </div>

                    <!-- Publication History Milestones -->
                    <div class="col-span-1 md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-4 border-t border-b py-4 my-2">
                        <h6 class="col-span-1 md:col-span-3 font-bold text-gray-600 text-sm uppercase">Publication History Timeline</h6>
                        <div class="mb-2">
                            <label class="block mb-1 text-xs font-semibold text-gray-500">Submitted</label>
                            <input id="date_submitted" name="date_submitted" type="date" class="w-full border rounded px-2 py-1.5 text-sm">
                        </div>
                        <div class="mb-2">
                            <label class="block mb-1 text-xs font-semibold text-gray-500">Final Revisions</label>
                            <input id="date_final_revision" name="date_final_revision" type="date" class="w-full border rounded px-2 py-1.5 text-sm">
                        </div>
                        <div class="mb-2">
                            <label class="block mb-1 text-xs font-semibold text-gray-500">Accepted</label>
                            <input id="date_accepted" name="date_accepted" type="date" class="w-full border rounded px-2 py-1.5 text-sm">
                        </div>
                        <div class="mb-2">
                            <label class="block mb-1 text-xs font-semibold text-gray-500">VOR Online</label>
                            <input id="date_vor_online" name="date_vor_online" type="date" class="w-full border rounded px-2 py-1.5 text-sm">
                        </div>
                        <div class="mb-2">
                            <label class="block mb-1 text-xs font-semibold text-gray-500">Open Access</label>
                            <input id="date_open_access" name="date_open_access" type="date" class="w-full border rounded px-2 py-1.5 text-sm">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            PDF File (Upload)
                            <input id="pdfFile" type="file" accept=".pdf" class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                        </label>
                        <!-- Progress Bar Container -->
                        <div id="uploadProgressContainer" class="hidden mt-2">
                            <div class="w-full bg-gray-200 rounded-full h-2.5">
                                <div id="uploadProgressBar" class="bg-blue-600 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
                            </div>
                            <p id="uploadStatus" class="text-xs text-gray-500 mt-1 text-right">Uploading...</p>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">
                            PDF URL
                            <input id="pdf_url" name="pdf_url"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50" 
                                type="url" placeholder="https://storage.googleapis.com/..." readonly>
                        </label>
                    </div>
                    <div class="mb-4 col-span-1 md:col-span-2">
                        <label class="block mb-1 text-gray-700">
                            Thumbnail URL
                            <input id="thumbnail_url" name="thumbnail_url"
                                class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                type="url" placeholder="https://storage.googleapis.com/...">
                        </label>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="block mb-1 text-gray-700">
                        Abstract
                        <textarea id="abstract" name="abstract" rows="4"
                            class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" 
                            placeholder="Abstract or summary of publication..."></textarea>
                    </label>
                </div>

                <div class="mb-4 flex space-x-6">
                    <label class="flex items-center text-gray-700">
                        <input id="is_visible" name="is_visible" type="checkbox" class="mr-2" checked>
                        Is Visible
                    </label>
                </div>
                
                <div class="text-center mt-6">
                    <button type="submit" class="bg-blue-500 text-white px-6 py-2 rounded hover:bg-blue-600 w-full sm:w-auto">
                        Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50">
    <div class="bg-white rounded-lg w-full max-w-md modal-content">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold">Confirm Delete</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeDeleteModal">
                <span>×</span>
            </button>
        </div>
        <div class="p-4">
            <p class="mb-4">Are you sure you want to delete this publication?</p>
            <div class="flex justify-end space-x-2">
                <button id="cancelDelete" class="bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 w-full sm:w-auto">
                    Cancel
                </button>
                <button id="confirmDelete" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 w-full sm:w-auto">
                    Delete
                </button>
            </div>
        </div>
    </div>
</div>
