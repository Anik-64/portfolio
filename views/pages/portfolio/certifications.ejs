<div class="container mx-auto px-6">
    <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold mb-4">Certifications</h2>
        <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
            Authorized proof of specialized skills and expertise in cloud and software technologies.
        </p>
    </div>

    <div id="certificationsGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Cards will be injected here -->
        <div class="col-span-full text-center py-20 text-gray-400 animate-pulse-slow">
            Validating credentials...
        </div>
    </div>

    <!-- Credly full profile callout -->
    <div id="credlyCallout" class="hidden mt-8 pt-6 border-t border-gray-100 dark:border-dark-border flex items-center justify-between gap-4 flex-wrap">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-orange-50 dark:bg-orange-900/20 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-award text-sm text-orange-500"></i>
            </div>
            <div>
                <p class="text-sm font-bold dark:text-white leading-tight">More badges on Credly</p>
                <p class="text-[11px] text-gray-400 mt-0.5">AWS learning path badges &amp; additional cloud credentials</p>
            </div>
        </div>
        <a id="credlyProfileLink" href="#" target="_blank"
        class="flex-shrink-0 flex items-center gap-2 px-4 py-2 text-xs font-bold rounded-lg border border-gray-200 dark:border-dark-border text-gray-600 dark:text-gray-300 hover:border-primary hover:text-primary transition-all">
            View full profile
            <i class="fas fa-external-link-alt text-[10px]"></i>
        </a>
    </div>
</div>

<!-- PDF Viewer Modal -->
<div id="certModal" class="fixed inset-0 z-[200] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-md" id="closeCertModal"></div>
    <div class="relative w-full max-w-5xl h-[85vh] bg-white dark:bg-dark-card rounded-2xl overflow-hidden shadow-2xl flex flex-col">
        <div class="flex items-center justify-between p-4 border-b border-gray-100 dark:border-dark-border">
            <h3 id="certModalTitle" class="font-bold truncate pr-8">Certificate Viewer</h3>
            <button class="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors" id="closeCertBtn">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="flex-grow bg-gray-100 dark:bg-dark-bg relative">
            <iframe id="certFrame" src="" class="w-full h-full border-none hidden"></iframe>
            <div id="certImageContainer" class="hidden w-full h-full items-center justify-center p-8 absolute inset-0">
                <img id="certImage" src="" alt="Certificate Badge" class="max-w-full max-h-full object-contain drop-shadow-xl rounded-xl">
            </div>
            <div id="certNoData" class="hidden w-full h-full items-center justify-center flex-col text-gray-400 absolute inset-0">
                <i class="fas fa-file-excel text-4xl mb-4 text-gray-300 dark:text-gray-600"></i>
                <p>No document or badge available.</p>
            </div>
        </div>
    </div>
</div>
