<div class="container mx-auto px-6">
    <div class="mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-[10px] font-bold uppercase tracking-[0.15em] rounded-full mb-3">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
            Experience
        </div>
        <h2 class="text-3xl font-bold mb-3 dark:text-white">Work experience</h2>
        <p class="text-gray-500 dark:text-gray-400 max-w-2xl text-sm leading-relaxed">
            A chronological journey through my professional career and the impact I've made at each role.
        </p>
    </div>

    <!-- Timeline -->
    <div class="relative pl-7 md:pl-9">
        <!-- Vertical line -->
        <div class="absolute left-[7px] md:left-[9px] top-1.5 bottom-1.5 w-px bg-gray-100 dark:bg-dark-border"></div>

        <div id="experienceTimeline" class="space-y-7">
            <!-- injected -->
            <div class="flex items-center justify-center py-20 animate-pulse-slow">
                <span class="text-gray-400 text-sm">Loading career milestones...</span>
            </div>
        </div>
    </div>
</div>
