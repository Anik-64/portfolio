<div class="relative min-h-screen flex items-center justify-center overflow-hidden">

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

            <!-- LEFT: Existing hero content -->
            <div class="text-center lg:text-left">
                <div class="inline-block px-3 py-1 mb-6 rounded-full border border-gray-100 dark:border-dark-border bg-gray-50/50 dark:bg-dark-card/50 backdrop-blur-sm text-xs font-medium text-gray-500 dark:text-gray-400 animate-fade-in">
                    Available for new opportunities
                </div>

                <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 dark:text-white">
                    Hi, I'm <span class="text-primary" id="heroName">Loading...</span>
                </h1>

                <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-10">
                    Backend Engineer & DevOps Enthusiast focused on scalable systems, cloud infrastructure and automation
                </p>

                <div class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-10 h-8">
                    <span id="typing-text"></span><span class="caret"></span>
                </div>

                <div class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4 animate-slide-up">
                    <a href="#projects" class="w-full sm:w-auto px-8 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-blue-600 transition-all shadow-lg shadow-primary/25">
                        View Projects
                    </a>
                    <a href="#" id="downloadResume" target="_blank" class="w-full sm:w-auto px-8 py-3 bg-white dark:bg-dark-card border border-gray-200 dark:border-dark-border font-semibold rounded-lg hover:border-primary/50 transition-all dark:text-white">
                        Download Resume
                    </a>
                </div>
            </div>

            <!-- RIGHT: Terminal -->
            <div class="hidden lg:block">
                <div class="rounded-2xl overflow-hidden border border-gray-800/60 dark:border-gray-700"
                     style="background:#0C1929;">
                    <!-- Traffic lights bar -->
                    <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/5">
                        <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                        <span class="w-2.5 h-2.5 rounded-full bg-amber-500/80"></span>
                        <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
                        <span class="ml-3 text-[10px] font-mono" style="color:rgba(133,183,235,0.35);">
                            pipeline status — prod
                        </span>
                        <span class="ml-auto flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                            <span class="text-[9px] font-mono text-green-400/60">live</span>
                        </span>
                    </div>
                    <!-- Terminal lines -->
                    <div class="p-5 font-mono text-xs leading-7 text-left" id="terminalLines">
                        <!-- injected by JS -->
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
        <i class="fas fa-chevron-down text-xl"></i>
    </div>
</div>
