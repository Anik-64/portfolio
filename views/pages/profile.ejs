<div class="container mx-auto">
    <!-- Floating message container -->
    <div id="floatingMessage" class="floating-message"></div>

    <div class="flex flex-col lg:flex-row gap-6 mt-4">
        <!-- Sidebar Profile Info -->
        <div class="w-full lg:w-1/3 space-y-6">
            <div class="bg-white shadow-md rounded-lg p-6 text-center">
                <div class="relative inline-block group mb-4">
                    <img id="profilePic" src="/images/avatar.jpg" alt="Profile" 
                         class="w-32 h-32 rounded-full object-cover border-4 border-blue-500 mx-auto">
                    <label for="profilePicUpload" class="absolute bottom-0 right-0 bg-blue-500 text-white p-2 rounded-full cursor-pointer hover:bg-blue-600 shadow-md">
                        <i class="fas fa-camera"></i>
                    </label>
                    <input type="file" id="profilePicUpload" class="hidden" accept="image/*">
                </div>
                <h2 id="displayFullName" class="text-xl font-bold text-gray-800">Your Name</h2>
                <p id="displayTagline" class="text-gray-500 text-sm italic">Tagline</p>
                <div class="mt-4 pt-4 border-t border-gray-100 flex justify-center space-x-4">
                    <a id="displayResume" href="#" target="_blank" class="text-blue-500 hover:text-blue-600 text-sm hidden">
                        <i class="fas fa-file-pdf mr-1"></i> View Resume
                    </a>
                </div>
            </div>

            <div class="bg-white shadow-md rounded-lg p-6">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-semibold text-gray-800">Contacts</h3>
                    <button id="addContactBtn" class="text-blue-500 hover:text-blue-600">
                        <i class="fas fa-plus-circle"></i> Add
                    </button>
                </div>
                <div id="contactsList" class="space-y-3">
                    <!-- Contacts will be loaded here -->
                </div>
            </div>
        </div>

        <!-- Main Profile Form -->
        <div class="w-full lg:w-2/3">
            <div class="bg-white shadow-md rounded-lg p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-6 border-b pb-2">Primary Information</h3>
                <form id="profileForm">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="mb-4">
                            <label class="block text-gray-700 text-sm font-bold mb-1">First Name <span class="text-red-500">*</span></label>
                            <input id="firstName" name="firstname" required
                                class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text">
                        </div>
                        <div class="mb-4">
                            <label class="block text-gray-700 text-sm font-bold mb-1">Last Name</label>
                            <input id="lastName" name="lastname"
                                class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-1">Tagline (comma separated)</label>
                        <input id="tagline" name="tagline" placeholder="e.g. Software Engineer, Tech Explorer"
                            class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text">
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-1">Biography</label>
                        <textarea id="bio" name="bio" rows="4"
                            class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-1">Biography (Backend Engineer)</label>
                        <textarea id="bioBackend" name="bio_backend" rows="4"
                            class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="mb-4">
                            <label class="block text-gray-700 text-sm font-bold mb-1">Resume URL</label>
                            <input id="resumeUrl" name="resume_url"
                                class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="url">
                        </div>
                        <div class="mb-4">
                            <label class="block text-gray-700 text-sm font-bold mb-1">Resume URL (Backend)</label>
                            <input id="resumeUrlBackend" name="resume_url_backend"
                                class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="url">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-1">Years of Experience</label>
                        <input id="experience" name="years_of_experience"
                            class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="number">
                    </div>

                    <div class="mt-6 flex justify-end">
                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded shadow transition duration-200">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Contact Modal -->
<div id="contactModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50">
    <div class="bg-white rounded-lg w-full max-w-md modal-content">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold" id="contactModalTitle">Add Contact Info</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeContactModal">
                <span>×</span>
            </button>
        </div>
        <div class="p-4">
            <form id="contactForm">
                <div class="mb-4">
                    <label class="block mb-1 text-sm font-bold text-gray-700">Type <span class="text-red-500">*</span></label>
                    <select id="contactType" name="contacttypeno" required
                        class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="">Select Type</option>
                        <!-- Dynamic options -->
                    </select>
                </div>
                <div class="mb-4">
                    <label class="block mb-1 text-sm font-bold text-gray-700">Contact Detail <span class="text-red-500">*</span></label>
                    <input id="contactDetail" name="contact" required placeholder="e.g. +123456789 or email@example.com"
                        class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text">
                </div>
                <div class="mb-4">
                    <label class="block mb-1 text-sm font-bold text-gray-700">Prefix (Optional)</label>
                    <input id="contactPrefix" name="contactprefix" placeholder="e.g. +88"
                        class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text">
                </div>
                <div class="mb-4">
                    <label class="block mb-1 text-sm font-bold text-gray-700">Note (Optional)</label>
                    <input id="contactNote" name="usenote" placeholder="e.g. WhatsApp"
                        class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text">
                </div>
                <div class="flex justify-end space-x-2 mt-6">
                    <button type="button" id="cancelContact" class="bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400">
                        Cancel
                    </button>
                    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 shadow">
                        Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50">
    <div class="bg-white rounded-lg w-full max-w-sm modal-content p-6">
        <h5 class="text-lg font-bold mb-4">Confirm Delete</h5>
        <p class="text-gray-600 mb-6 text-sm">Are you sure you want to remove this contact entry?</p>
        <div class="flex justify-end space-x-2">
            <button id="cancelDelete" class="bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300">No, Keep it</button>
            <button id="confirmDelete" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 shadow">Yes, Delete</button>
        </div>
    </div>
</div>
