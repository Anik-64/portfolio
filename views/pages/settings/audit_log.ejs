<div class="container mx-auto">
    <!-- Floating message container -->
    <div id="floatingMessage" class="floating-message"></div>

    <div class="flex justify-between items-center mt-4 mb-6 flex-col sm:flex-row gap-4 sm:gap-0 page-header">
        <h1 class="text-xl font-bold"><%= title %></h1>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-2 w-full sm:w-auto">
            <input id="searchInput" type="text" placeholder="Search logs (action, user, table)..." 
                class="border rounded px-3 py-2 w-full sm:w-72 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white shadow-md rounded-lg p-4 md:p-6">
        <div class="table-container">
            <div class="table-responsive">
                <table id="dataTable" class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">ID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">User ID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Action</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Table Name</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Record ID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Timestamp</th>
                            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider">Old Data</th>
                            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider">New Data</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <!-- Data will be loaded via JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- View Details Modal (Old Data) -->
<div id="oldDataModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50 overflow-y-auto">
    <div class="bg-white rounded-lg w-full max-w-2xl modal-content relative my-auto">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold cursor-pointer">Old Data</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeOldDataModal">
                <span>×</span>
            </button>
        </div>
        <div class="p-4 max-h-[70vh] overflow-y-auto bg-gray-50">
            <pre id="oldDataContent" class="text-sm text-gray-800 whitespace-pre-wrap font-mono"></pre>
        </div>
    </div>
</div>

<!-- View Details Modal (New Data) -->
<div id="newDataModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50 overflow-y-auto">
    <div class="bg-white rounded-lg w-full max-w-2xl modal-content relative my-auto">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold cursor-pointer">New Data</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeNewDataModal">
                <span>×</span>
            </button>
        </div>
        <div class="p-4 max-h-[70vh] overflow-y-auto bg-gray-50">
            <pre id="newDataContent" class="text-sm text-gray-800 whitespace-pre-wrap font-mono"></pre>
        </div>
    </div>
</div>
