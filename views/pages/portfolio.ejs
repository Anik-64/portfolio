<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%230C1929'/><text x='5' y='22' font-family='monospace' font-size='16' font-weight='bold' fill='%231D9E75'>%3E_</text></svg>">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#3B82F6', // Blue
                        dark: {
                            bg: '#0A0A0A',
                            card: '#141414',
                            border: '#262626'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'DM Sans', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    animation: {
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>

    <style>
        @keyframes loaderFadeUp {
            from { opacity: 0; transform: translateY(4px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes loaderBlink {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0; }
        }
        #pageLoader.fade-out {
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
        }
    </style>
    
    <link rel="stylesheet" href="/css/portfolio.css">
</head>
<body class="bg-white dark:bg-dark-bg text-gray-900 dark:text-gray-100 transition-colors duration-300">

    <!-- ── Page Loader ── -->
    <div id="pageLoader" class="fixed inset-0 z-[999] flex items-center justify-center flex-col gap-8"
         style="background:#0A0A0A;">
        
        <!-- Orbiting rings -->
        <div class="relative w-[72px] h-[72px]">
            <div class="absolute inset-0 rounded-full animate-spin"
                 style="border:1.5px solid transparent; border-top-color:#1D9E75; animation-duration:1.2s;"></div>
            <div class="absolute rounded-full"
                 style="inset:10px; border:1.5px solid transparent; border-top-color:#378ADD;
                        animation: spin 1.8s linear infinite reverse;">
            </div>
            <div class="absolute inset-0 flex items-center justify-center text-xl"
                 style="color:#85B7EB;">⚙</div>
        </div>

        <!-- Terminal lines -->
        <div class="flex flex-col gap-1.5 font-mono text-[11px]" style="width:280px;">
            <div class="loader-line opacity-0" style="animation: loaderFadeUp 0.4s 0.1s forwards;">
                <span style="color:#1D9E75;">→ </span>
                <span style="color:#85B7EB;">initializing portfolio...</span>
            </div>
            <div class="loader-line opacity-0" style="animation: loaderFadeUp 0.4s 0.5s forwards;">
                <span style="color:#1D9E75;">→ ✓ </span>
                <span style="color:#1D9E75;">connecting to services</span>
            </div>
            <div class="loader-line opacity-0" style="animation: loaderFadeUp 0.4s 0.9s forwards;">
                <span style="color:#1D9E75;">→ ✓ </span>
                <span style="color:#1D9E75;">loading credentials</span>
            </div>
            <div class="loader-line opacity-0 flex items-center gap-1" style="animation: loaderFadeUp 0.4s 1.3s forwards;">
                <span style="color:rgba(133,183,235,0.3);">  mounting components</span>
                <span class="inline-block w-[7px] h-[13px] align-middle"
                      style="background:#1D9E75; animation: loaderBlink 0.8s step-end infinite;"></span>
            </div>
        </div>

        <!-- Progress bar -->
        <div style="width:280px;">
            <div class="flex justify-between font-mono mb-1.5"
                 style="font-size:9px; color:rgba(133,183,235,0.35); letter-spacing:0.1em; text-transform:uppercase;">
                <span>build pipeline</span>
                <span id="loaderPercent">0%</span>
            </div>
            <div class="rounded-full overflow-hidden" style="height:2px; background:rgba(133,183,235,0.08);">
                <div id="loaderBar" class="h-full rounded-full"
                     style="width:0%; background:linear-gradient(90deg,#1D9E75,#378ADD); transition: width 0.3s ease;"></div>
            </div>
        </div>

    </div>

    <!-- Grid Dot Background -->
    <div class="fixed inset-0 z-[-1] pointer-events-none opacity-[0.03] dark:opacity-[0.07]" style="background-image: radial-gradient(#3B82F6 1px, transparent 1px); background-size: 32px 32px;"></div>

    <!-- Navigation -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-[100] border-b border-transparent transition-all duration-300 backdrop-blur-md">
        <div class="container mx-auto px-6 h-20 flex items-center justify-between">
            <a href="#hero" class="text-xl font-bold tracking-tight">Anik.</a>
            
            <div class="hidden md:flex items-center space-x-8">
                <a href="#about" class="nav-link">About</a>
                <a href="#skills" class="nav-link">Skills</a>
                <a href="#experience" class="nav-link">Experience</a>
                <a href="#projects" class="nav-link">Projects</a>
                <a href="#contact" class="nav-link">Contact</a>

                <!-- <a href="#contact"
                    class="px-4 py-2 text-xs font-bold rounded-lg text-white transition-all"
                    style="background:#185FA5;"
                    onmouseover="this.style.background='#0C447C'"
                    onmouseout="this.style.background='#185FA5'">
                        Hire Me
                </a> -->
                
                <button id="themeToggle" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                    <i class="fas fa-moon dark:hidden"></i>
                    <i class="fas fa-sun hidden dark:block"></i>
                </button>
            </div>
            
            <button class="md:hidden text-2xl" id="menuToggle">
                <i class="fas fa-bars"></i>
            </button>
        </div>
        
        <!-- Mobile Menu -->
        <div id="mobileMenu" class="md:hidden hidden absolute top-20 left-0 right-0 bg-white dark:bg-dark-bg border-b border-gray-100 dark:border-dark-border px-6 py-8 flex flex-col space-y-6">
            <a href="#about" class="mobile-nav-link">About</a>
            <a href="#skills" class="mobile-nav-link">Skills</a>
            <a href="#experience" class="mobile-nav-link">Experience</a>
            <a href="#projects" class="mobile-nav-link">Projects</a>
            <a href="#contact" class="mobile-nav-link">Contact</a>
        </div>
    </nav>

    <main>
        <section id="hero">
            <%- include('portfolio/hero') %>
        </section>
        
        <section id="about" class="section">
            <%- include('portfolio/about') %>
        </section>
        
        <section id="skills" class="section">
            <%- include('portfolio/skills') %>
        </section>
        
        <section id="experience" class="section">
            <%- include('portfolio/experience') %>
        </section>
        
        <section id="projects" class="section">
            <%- include('portfolio/projects') %>
        </section>
        
        <div id="secondary-sections">
            <section id="certifications" class="section">
                <%- include('portfolio/certifications') %>
            </section>
            
            <section id="publications" class="section">
                <%- include('portfolio/publications') %>
            </section>
            
            <section id="education" class="section">
                <%- include('portfolio/education_trainings') %>
            </section>
        </div>
        
        <section id="contact" class="section">
            <%- include('portfolio/contact') %>
        </section>
    </main>

    <!-- Footer -->
    <%- include('portfolio/footer') %>

    <!-- State & Data -->
    <script>
        window.PORTFOLIO_STATE = {
            data: null,
            theme: localStorage.getItem('theme') || 'dark'
        };
    </script>
    
    <!-- Scripts -->
    <script src="/js/portfolio.js"></script>
    
    <!-- Vercel Web Analytics -->
    <script defer src="/_vercel/insights/script.js"></script>
</body>
</html>
