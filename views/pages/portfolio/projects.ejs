            <p class="text-gray-600 dark:text-gray-400 max-w-xl text-center md:text-left">
                A showcase of my recent work across different domains and technology stacks.
            </p>
        </div>
        
        <!-- Filter Controls -->
        <div id="projectFilters" class="flex flex-wrap items-center justify-center gap-2 p-1 bg-gray-50 dark:bg-dark-card rounded-xl border border-gray-100 dark:border-dark-border">
            <!-- Dynamically injected filters -->
        </div>
    </div>

    <div id="projectGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Project cards will be injected here -->
        <div class="col-span-full flex items-center justify-center py-40 animate-pulse-slow">
            <span class="text-gray-400 text-lg">Brewing some projects...</span>
        </div>
    </div>
</div>

