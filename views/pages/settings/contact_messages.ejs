<div class="container mx-auto">
    <!-- Floating message container -->
    <div id="floatingMessage" class="floating-message"></div>

    <div class="flex justify-between items-center mt-4 mb-6 flex-col sm:flex-row gap-4 sm:gap-0 page-header">
        <h1 class="text-xl font-bold"><%= title %></h1>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-2 w-full sm:w-auto">
            <button id="addBtn" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded w-full sm:w-auto">
                <i class="fas fa-plus text-xs"></i> Add Contact Message
            </button>
            <input id="searchInput" type="text" placeholder="Search by name, email, or subject..." 
                class="border rounded px-3 py-2 w-full sm:w-64 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white shadow-md rounded-lg p-4 md:p-6">
        <div class="table-container">
            <div class="table-responsive">
                <table id="dataTable" class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">ID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Name/Email</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Subject</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Date</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Status</th>
                            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <!-- Data will be loaded via JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div id="dataModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50 overflow-y-auto">
    <div class="bg-white rounded-lg w-full max-w-lg modal-content relative my-auto">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold" id="modalTitle">View Contact Message</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeModal">
                <span>×</span>
            </button>
        </div>
        <div class="modal-form-container p-4 max-h-[80vh] overflow-y-auto">
            <form id="dataForm">
                <div class="grid grid-cols-1 gap-4">
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">Name</label>
                        <input id="name" name="name" required class="w-full border rounded px-3 py-2 mt-1 bg-gray-50" type="text" readonly>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">Email</label>
                        <input id="email" name="email" required class="w-full border rounded px-3 py-2 mt-1 bg-gray-50" type="email" readonly>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">Subject</label>
                        <input id="subject" name="subject" class="w-full border rounded px-3 py-2 mt-1 bg-gray-50" type="text" readonly>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700">Message</label>
                        <textarea id="message" name="message" rows="5" class="w-full border rounded px-3 py-2 mt-1 bg-gray-50" readonly></textarea>
                    </div>
                    
                    <div class="mb-4">
                        <label class="block mb-1 text-gray-700 font-semibold border-t pt-4">Update Status</label>
                        <select id="status" name="status" class="w-full border rounded px-3 py-2 mt-1 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="new">New</option>
                            <option value="read">Read</option>
                            <option value="replied">Replied</option>
                        </select>
                        <p class="text-xs text-gray-500 mt-2">Only the status can be modified to keep message history intact.</p>
                    </div>
                </div>

                <div id="addFieldsGroup" class="hidden border-t pt-4 mt-4">
                    <!-- Fields specific to manual entry if they want to add one -->
                    <p class="text-sm font-semibold mb-2">Notice: Usually messages are submitted by users via the frontend form, but you can manually add one here.</p>
                </div>
                
                <div class="text-center mt-6">
                    <button type="submit" class="bg-blue-500 text-white px-6 py-2 rounded hover:bg-blue-600 w-full sm:w-auto">
                        Save Status
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 hidden z-50">
    <div class="bg-white rounded-lg w-full max-w-md modal-content">
        <div class="flex justify-between items-center p-4 border-b">
            <h5 class="text-lg font-semibold">Confirm Delete</h5>
            <button type="button" class="close text-gray-600 hover:text-gray-800" id="closeDeleteModal">
                <span>×</span>
            </button>
        </div>
        <div class="p-4">
            <p class="mb-4">Are you sure you want to delete this message forever?</p>
            <div class="flex justify-end space-x-2">
                <button id="cancelDelete" class="bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 w-full sm:w-auto">
                    Cancel
                </button>
                <button id="confirmDelete" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 w-full sm:w-auto">
                    Delete
                </button>
            </div>
        </div>
    </div>
</div>
